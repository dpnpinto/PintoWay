#!/bin/sh

# Appearance
riverctl background-color 0x000000
riverctl border-color-focused 0xff7a93
riverctl border-color-unfocused 0x00ffd2
riverctl border-width 2

# Keyboard layout
riverctl keyboard-layout pt

# Terminal
riverctl map normal Super Return spawn foot

# Close window
riverctl map normal Super Q close

# App launcher
riverctl map normal Super D spawn fuzzel

# File manager
riverctl map normal Super S spawn thunar

# Start status bar
yambar &
